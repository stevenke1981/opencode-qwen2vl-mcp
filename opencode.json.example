{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "opencode-qwen2vl-mcp": {
      "type": "local",
      "command": [
        "pwsh",
        "-NoProfile",
        "-Command",
        "node \"$env:USERPROFILE\\.config\\opencode-qwen2vl-mcp\\dist\\index.js\""
      ],
      "enabled": true,
      "timeout": 300000
    }
  }
}